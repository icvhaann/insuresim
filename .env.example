# DeepSeek API key — required.
DEEPSEEK_API_KEY=

# Model. Defaults to deepseek-chat (DeepSeek-V3.2 non-thinking). Do NOT use
# deepseek-reasoner — JSON mode + complex system prompts behave worse.
DEEPSEEK_MODEL=deepseek-chat

# Token to gate /api/admin/log, /api/admin/log.json, and /facilitator.
# Generate a long random string. Treat as a secret.
ADMIN_TOKEN=

# Optional. Defaults to 3000.
PORT=3000
