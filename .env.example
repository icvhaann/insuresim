# DeepSeek API key — required.
DEEPSEEK_API_KEY=

# Model identifier. Defaults to deepseek-chat (DeepSeek-V3.2 non-thinking mode).
# Other options: deepseek-reasoner (V3.2 thinking — NOT recommended for this app, JSON mode + complex system prompts behave worse).
# When V4 lands on the public API, change here.
DEEPSEEK_MODEL=deepseek-chat

# Token to gate /api/admin/log. If unset, the export endpoint returns 503.
# Generate a long random string. Treat as a secret.
ADMIN_TOKEN=

# Optional. Defaults to 3000.
PORT=3000
